# 공공데이터 API
COOKRCP01_API_KEY=your_api_key_here

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=ap-northeast-2
AWS_OUTPUT_FORMAT=json

# S3 Vectors
S3_VECTOR_BUCKET=recipe-vectors
S3_VECTOR_INDEX=recipe-index

# S3 이미지
S3_IMAGE_BUCKET=bedrock-2-recipe-images

# RDS
DATABASE_URL=postgresql://postgres:password@your-rds-endpoint:5432/postgres

# JWT
JWT_SECRET=your_jwt_secret_here

# API Gateway
API_GATEWAY_URL=https://your-api-gateway-url.execute-api.ap-northeast-2.amazonaws.com